{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Desktop capability for shell, SQL, updater, and process access",
  "windows": ["main"],
  "permissions": [
    "shell:allow-open",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default",
    "process:default"
  ]
}
