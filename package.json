{
  "name": "vitpos-bootstrap",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "workspaces": ["apps/api"],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run api:dev\" \"vite\"",
    "build": "npm run api:build && tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "api:dev": "npm run dev --prefix apps/api",
    "api:test": "npm test --prefix apps/api",
    "api:typecheck": "npm run typecheck --prefix apps/api",
    "api:build": "npm run build --prefix apps/api",
    "api:check": "npm run api:test && npm run api:typecheck && npm run api:build",
    "desktop:check": "npm run check --prefix apps/desktop",
    "mobile:check": "npm run check --prefix apps/mobile",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed:baim": "node scripts/seed-baim.mjs",
    "db:seed:admin": "node scripts/seed-platform-admin.mjs",
    "db:studio": "drizzle-kit studio",
    "preview": "vite preview"
  },
  "dependencies": {
    "2": "^3.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
