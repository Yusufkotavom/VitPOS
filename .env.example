# PostgreSQL connection used by Drizzle and server-side database utilities.
# Copy to .env.local and replace every placeholder. Do not commit real secrets.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Web app base URL for standalone API deployment.
VITE_API_BASE_URL="http://localhost:3010"

# Seed demo data only when explicitly needed in local development.
VITE_ENABLE_DEMO_SEED="false"

# Cloudflare R2 — for invoice logo upload
# Copy from: R2 Dashboard → Manage API Tokens → Create API Token (Object Read & Write)
# R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="vitpos-uploads"
# Optional: set public URL for direct image serving (R2 → Settings → Public Access)
R2_PUBLIC_URL=""

# Tauri updater signing — required for `npm run tauri:build` to sign release artifacts.
# Generate a keypair once with:
#   node node_modules/.bin/tauri signer generate -w .tauri-private.key -p "YOUR_PASSWORD" --ci
# The public key (.tauri-private.key.pub) goes in apps/desktop/src-tauri/tauri.conf.json → plugins.updater.pubkey.
# Point TAURI_SIGNING_PRIVATE_KEY_PATH at the private key file (keep the file gitignored),
# or set TAURI_SIGNING_PRIVATE_KEY to the base64-encoded key string directly.
TAURI_SIGNING_PRIVATE_KEY_PATH=".tauri-private.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""
