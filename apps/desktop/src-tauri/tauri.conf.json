{
  "productName": "KOTACOM Business Suite",
  "version": "0.0.0",
  "identifier": "com.kotacom.vitpos",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../../",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KOTACOM Business Suite",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {
      "preload": ["sqlite:vitpos.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxNEI0OEE2ODgwQTJBOUUKUldTZUtncUlwa2hMUVlwdDArbVdITlkyazhidGJGUytSMFlnL2ZWVGpUcjBib2t0WlgvWFdlK0kK",
      "endpoints": [
        "https://vit-pos-8vle.vercel.app/api/v1/updates/desktop/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
